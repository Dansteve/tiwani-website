# Copy this file to .env and fill in the values. .env is gitignored; never commit real keys.

# SheetMonkey endpoint: the secondary Google Sheet copy of each waitlist signup.
NEXT_PUBLIC_WAITLIST_ENDPOINT=https://api.sheetmonkey.io/form/YOUR_FORM_ID

# Supabase: the primary waitlist DB write (insert into the public.waitlist table).
# The URL is public. For the client key, set ONE of the two below (the code prefers the
# publishable key): NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY is Supabase's newer publishable key
# (sb_publishable_...); NEXT_PUBLIC_SUPABASE_ANON_KEY is the legacy anon-JWT name. Both are public
# client keys; the insert is still gated by row level security server-side.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_LEGACY_ANON_KEY

# Optional override for the "Go to dashboard" link target (the tiwani-app URL).
# Left unset, it defaults to http://localhost:3000 in dev and https://app-tiwani.web.app in the
# production build. Set this to a custom domain (e.g. https://app.tiwanilife.com) if one is added.
NEXT_PUBLIC_APP_URL=
