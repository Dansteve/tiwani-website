# Copy this file to .env and fill in the values
VITE_WAITLIST_ENDPOINT=https://api.sheetmonkey.io/form/YOUR_FORM_ID

# Optional override for the "Go to dashboard" link target (the tiwani-app URL).
# Left unset, it defaults to http://localhost:3000 in dev and https://app-tiwani.web.app in the
# production build. Set this to a custom domain (e.g. https://app.tiwanilife.com) if one is added.
VITE_APP_URL=
